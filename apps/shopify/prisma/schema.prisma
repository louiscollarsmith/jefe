generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Merchant {
  id                 String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  status             String                        @default("active")
  createdAt          DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  shops              Shop[]
  ledgerEvents       LedgerEvent[]
  products           Product[]
  variants           Variant[]
  orders             Order[]
  orderLineItems     OrderLineItem[]
  refunds            Refund[]
  inventoryLevels    InventoryLevel[]
  customerIdentities CustomerIdentity[]
  connectorAccounts  ConnectorAccount[]
  backfillStatuses   ShopBackfillStatus[]
  backfillJobs       BackfillJob[]
  memoryBeliefs      MerchantMemoryBelief[]
  memoryEvidence     MerchantMemoryEvidence[]
  memoryHistory      MerchantMemoryBeliefHistory[]
  memoryRefreshRuns  MerchantMemoryRefreshRun[]

  @@map("merchants")
}

model Shop {
  id                        String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId                String                        @map("merchant_id") @db.Uuid
  platform                  String                        @default("shopify")
  shopDomain                String                        @map("shop_domain")
  externalShopId            String?                       @map("external_shop_id")
  status                    String                        @default("active")
  setupStatus               String                        @default("installed") @map("setup_status")
  historicalOrderAccess     String                        @default("unknown") @map("historical_order_access")
  availableOrderHistoryDays Int                           @default(0) @map("available_order_history_days")
  backfillStartedAt         DateTime?                     @map("backfill_started_at") @db.Timestamptz(6)
  backfillCompletedAt       DateTime?                     @map("backfill_completed_at") @db.Timestamptz(6)
  rawPayload                Json                          @default("{}") @map("raw_payload")
  createdAt                 DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant                  Merchant                      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  ledgerEvents              LedgerEvent[]
  products                  Product[]
  variants                  Variant[]
  orders                    Order[]
  orderLineItems            OrderLineItem[]
  refunds                   Refund[]
  inventoryLevels           InventoryLevel[]
  customerIdentities        CustomerIdentity[]
  connectorAccounts         ConnectorAccount[]
  backfillStatuses          ShopBackfillStatus[]
  backfillJobs              BackfillJob[]
  memoryBeliefs             MerchantMemoryBelief[]
  memoryEvidence            MerchantMemoryEvidence[]
  memoryHistory             MerchantMemoryBeliefHistory[]
  memoryRefreshRuns         MerchantMemoryRefreshRun[]

  @@unique([platform, shopDomain])
  @@index([merchantId])
  @@map("shops")
}

model ConnectorAccount {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId        String    @map("merchant_id") @db.Uuid
  shopId            String?   @map("shop_id") @db.Uuid
  connector         String
  accountExternalId String?   @map("account_external_id")
  status            String    @default("active")
  scopes            String[]  @default([])
  readTokenRef      String?   @map("read_token_ref")
  writeTokenRef     String?   @map("write_token_ref")
  authMetadata      Json      @default("{}") @map("auth_metadata")
  rawPayload        Json      @default("{}") @map("raw_payload")
  connectedAt       DateTime? @map("connected_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant          Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop              Shop?     @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@unique([merchantId, connector, accountExternalId])
  @@index([shopId])
  @@map("connector_accounts")
}

model LedgerEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId     String   @map("merchant_id") @db.Uuid
  shopId         String?  @map("shop_id") @db.Uuid
  eventType      String   @map("event_type")
  source         String
  sourceEventId  String?  @map("source_event_id")
  dedupeKey      String?  @map("dedupe_key")
  idempotencyKey String?  @map("idempotency_key")
  actorType      String?  @map("actor_type")
  actorId        String?  @map("actor_id")
  payload        Json     @default("{}")
  rawPayload     Json     @default("{}") @map("raw_payload")
  eventTs        DateTime @default(now()) @map("event_ts") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  merchant       Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop           Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@unique([merchantId, dedupeKey])
  @@unique([merchantId, idempotencyKey])
  @@index([merchantId, eventType, eventTs])
  @@index([shopId, eventTs])
  @@map("ledger_events")
}

model Product {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId      String          @map("merchant_id") @db.Uuid
  shopId          String          @map("shop_id") @db.Uuid
  externalId      String          @map("external_id")
  title           String
  handle          String?
  status          String?
  vendor          String?
  productType     String?         @map("product_type")
  sourceCreatedAt DateTime?       @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt DateTime?       @map("source_updated_at") @db.Timestamptz(6)
  rawPayload      Json            @default("{}") @map("raw_payload")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant        Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop            Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variants        Variant[]
  lineItems       OrderLineItem[]

  @@unique([shopId, externalId])
  @@index([merchantId])
  @@map("products")
}

model Variant {
  id                      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId              String           @map("merchant_id") @db.Uuid
  shopId                  String           @map("shop_id") @db.Uuid
  productId               String           @map("product_id") @db.Uuid
  externalId              String           @map("external_id")
  sku                     String?
  title                   String?
  price                   Decimal?         @db.Decimal(18, 2)
  currency                String?          @default("GBP")
  inventoryItemExternalId String?          @map("inventory_item_external_id")
  sourceCreatedAt         DateTime?        @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt         DateTime?        @map("source_updated_at") @db.Timestamptz(6)
  rawPayload              Json             @default("{}") @map("raw_payload")
  createdAt               DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant                Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop                    Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product                 Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  lineItems               OrderLineItem[]
  inventoryLevels         InventoryLevel[]

  @@unique([shopId, externalId])
  @@index([merchantId])
  @@index([productId])
  @@map("variants")
}

model Order {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId         String          @map("merchant_id") @db.Uuid
  shopId             String          @map("shop_id") @db.Uuid
  externalId         String          @map("external_id")
  orderName          String?         @map("order_name")
  customerExternalId String?         @map("customer_external_id")
  financialStatus    String?         @map("financial_status")
  fulfillmentStatus  String?         @map("fulfillment_status")
  currency           String          @default("GBP")
  subtotalPrice      Decimal?        @map("subtotal_price") @db.Decimal(18, 2)
  totalPrice         Decimal?        @map("total_price") @db.Decimal(18, 2)
  totalDiscount      Decimal?        @map("total_discount") @db.Decimal(18, 2)
  totalTax           Decimal?        @map("total_tax") @db.Decimal(18, 2)
  totalShipping      Decimal?        @map("total_shipping") @db.Decimal(18, 2)
  sourceCreatedAt    DateTime?       @map("source_created_at") @db.Timestamptz(6)
  sourceUpdatedAt    DateTime?       @map("source_updated_at") @db.Timestamptz(6)
  processedAt        DateTime?       @map("processed_at") @db.Timestamptz(6)
  rawPayload         Json            @default("{}") @map("raw_payload")
  createdAt          DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant           Merchant        @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop               Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  lineItems          OrderLineItem[]
  refunds            Refund[]

  @@unique([shopId, externalId])
  @@index([merchantId, processedAt])
  @@index([shopId, processedAt])
  @@map("orders")
}

model OrderLineItem {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId          String   @map("merchant_id") @db.Uuid
  shopId              String   @map("shop_id") @db.Uuid
  orderId             String   @map("order_id") @db.Uuid
  productId           String?  @map("product_id") @db.Uuid
  variantId           String?  @map("variant_id") @db.Uuid
  externalId          String   @map("external_id")
  sku                 String?
  title               String?
  quantity            Int      @default(0)
  unitPrice           Decimal? @map("unit_price") @db.Decimal(18, 2)
  totalPrice          Decimal? @map("total_price") @db.Decimal(18, 2)
  discount            Decimal? @db.Decimal(18, 2)
  discountAllocations Json     @default("[]") @map("discount_allocations")
  rawPayload          Json     @default("{}") @map("raw_payload")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant            Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop                Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product             Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant             Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([orderId, externalId])
  @@index([merchantId])
  @@index([shopId])
  @@index([productId])
  @@index([variantId])
  @@map("order_line_items")
}

model Refund {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId      String    @map("merchant_id") @db.Uuid
  shopId          String    @map("shop_id") @db.Uuid
  orderId         String    @map("order_id") @db.Uuid
  externalId      String    @map("external_id")
  amount          Decimal?  @db.Decimal(18, 2)
  currency        String?   @default("GBP")
  reason          String?
  sourceCreatedAt DateTime? @map("source_created_at") @db.Timestamptz(6)
  processedAt     DateTime? @map("processed_at") @db.Timestamptz(6)
  rawPayload      Json      @default("{}") @map("raw_payload")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant        Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop            Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([shopId, externalId])
  @@index([merchantId, processedAt])
  @@index([orderId])
  @@map("refunds")
}

model InventoryLevel {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId              String    @map("merchant_id") @db.Uuid
  shopId                  String    @map("shop_id") @db.Uuid
  variantId               String?   @map("variant_id") @db.Uuid
  inventoryItemExternalId String    @map("inventory_item_external_id")
  locationExternalId      String    @map("location_external_id")
  available               Int?
  committed               Int?
  incoming                Int?
  sourceUpdatedAt         DateTime? @map("source_updated_at") @db.Timestamptz(6)
  observedAt              DateTime  @default(now()) @map("observed_at") @db.Timestamptz(6)
  rawPayload              Json      @default("{}") @map("raw_payload")
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant                Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop                    Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  variant                 Variant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([shopId, inventoryItemExternalId, locationExternalId])
  @@index([merchantId, observedAt])
  @@index([variantId])
  @@map("inventory_levels")
}

model CustomerIdentity {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId        String    @map("merchant_id") @db.Uuid
  shopId            String    @map("shop_id") @db.Uuid
  normalizedEmail   String?   @map("normalized_email")
  emailHash         String    @map("email_hash")
  maskedEmail       String?   @map("masked_email")
  firstSeenOrderAt  DateTime? @map("first_seen_order_at") @db.Timestamptz(6)
  lastOrderAt       DateTime? @map("last_order_at") @db.Timestamptz(6)
  orderCount        Int       @default(0) @map("order_count")
  totalSpend        Decimal   @default(0) @map("total_spend") @db.Decimal(18, 2)
  averageOrderValue Decimal   @default(0) @map("average_order_value") @db.Decimal(18, 2)
  source            String
  shopifyCustomerId String?   @map("shopify_customer_id")
  rawPayload        Json      @default("{}") @map("raw_payload")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant          Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop              Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, emailHash])
  @@index([merchantId, lastOrderAt])
  @@map("customer_identities")
}

model ShopBackfillStatus {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId           String    @map("merchant_id") @db.Uuid
  shopId               String    @map("shop_id") @db.Uuid
  domain               String
  status               String    @default("queued")
  startedAt            DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt          DateTime? @map("completed_at") @db.Timestamptz(6)
  lastError            String?   @map("last_error")
  recordsProcessed     Int       @default(0) @map("records_processed")
  totalRecordsEstimate Int?      @map("total_records_estimate")
  lastCursor           String?   @map("last_cursor")
  bulkOperationId      String?   @map("bulk_operation_id")
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant             Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop                 Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, domain])
  @@index([merchantId, status])
  @@map("shop_backfill_statuses")
}

model BackfillJob {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId   String    @map("merchant_id") @db.Uuid
  shopId       String    @map("shop_id") @db.Uuid
  jobType      String    @map("job_type")
  status       String    @default("queued")
  priority     Int       @default(100)
  attemptCount Int       @default(0) @map("attempt_count")
  maxAttempts  Int       @default(3) @map("max_attempts")
  runAfter     DateTime  @default(now()) @map("run_after") @db.Timestamptz(6)
  startedAt    DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)
  failedAt     DateTime? @map("failed_at") @db.Timestamptz(6)
  lastError    String?   @map("last_error")
  payloadJson  Json      @default("{}") @map("payload_json")
  resultJson   Json      @default("{}") @map("result_json")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant     Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop         Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, jobType])
  @@index([status, runAfter, priority])
  @@index([merchantId, status])
  @@map("backfill_jobs")
}

model MerchantMemoryBelief {
  id                 String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId         String                        @map("merchant_id") @db.Uuid
  shopId             String?                       @map("shop_id") @db.Uuid
  category           String
  key                String
  value              Json                          @default("{}") @map("value_json")
  valueType          String                        @map("value_type")
  status             String                        @default("inferred")
  confidence         Decimal?                      @db.Decimal(5, 4)
  confidenceReason   String?                       @map("confidence_reason")
  precedence         Int                           @default(20)
  derivationVersion  String?                       @map("derivation_version")
  firstObservedAt    DateTime?                     @map("first_observed_at") @db.Timestamptz(6)
  lastObservedAt     DateTime?                     @map("last_observed_at") @db.Timestamptz(6)
  lastEvaluatedAt    DateTime?                     @map("last_evaluated_at") @db.Timestamptz(6)
  lastConfirmedAt    DateTime?                     @map("last_confirmed_at") @db.Timestamptz(6)
  supersededAt       DateTime?                     @map("superseded_at") @db.Timestamptz(6)
  supersedesBeliefId String?                       @map("supersedes_belief_id") @db.Uuid
  createdAt          DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                      @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant           Merchant                      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop               Shop?                         @relation(fields: [shopId], references: [id], onDelete: SetNull)
  supersedesBelief   MerchantMemoryBelief?         @relation("MerchantMemoryBeliefSupersession", fields: [supersedesBeliefId], references: [id], onDelete: SetNull)
  supersededBy       MerchantMemoryBelief[]        @relation("MerchantMemoryBeliefSupersession")
  evidence           MerchantMemoryEvidence[]
  history            MerchantMemoryBeliefHistory[]

  @@index([merchantId, category, key])
  @@index([merchantId, status])
  @@index([shopId])
  @@index([supersedesBeliefId])
  @@map("merchant_memory_beliefs")
}

model MerchantMemoryEvidence {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId      String                @map("merchant_id") @db.Uuid
  shopId          String?               @map("shop_id") @db.Uuid
  beliefId        String?               @map("belief_id") @db.Uuid
  sourceType      String                @map("source_type")
  sourceReference String?               @map("source_reference")
  evidenceType    String                @map("evidence_type")
  summary         String
  metadata        Json                  @default("{}")
  observedAt      DateTime?             @map("observed_at") @db.Timestamptz(6)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  merchant        Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop            Shop?                 @relation(fields: [shopId], references: [id], onDelete: SetNull)
  belief          MerchantMemoryBelief? @relation(fields: [beliefId], references: [id], onDelete: Cascade)

  @@index([merchantId, evidenceType, createdAt])
  @@index([beliefId, createdAt])
  @@index([shopId])
  @@map("merchant_memory_evidence")
}

model MerchantMemoryBeliefHistory {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId     String                @map("merchant_id") @db.Uuid
  shopId         String?               @map("shop_id") @db.Uuid
  beliefId       String?               @map("belief_id") @db.Uuid
  key            String
  previousStatus String?               @map("previous_status")
  newStatus      String                @map("new_status")
  previousValue  Json?                 @map("previous_value_json")
  newValue       Json?                 @map("new_value_json")
  changeReason   String                @map("change_reason")
  changedBy      String                @default("system") @map("changed_by")
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  merchant       Merchant              @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop           Shop?                 @relation(fields: [shopId], references: [id], onDelete: SetNull)
  belief         MerchantMemoryBelief? @relation(fields: [beliefId], references: [id], onDelete: SetNull)

  @@index([merchantId, key, createdAt])
  @@index([beliefId, createdAt])
  @@index([shopId])
  @@map("merchant_memory_belief_history")
}

model MerchantMemoryRefreshRun {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId          String    @map("merchant_id") @db.Uuid
  shopId              String?   @map("shop_id") @db.Uuid
  refreshType         String    @map("refresh_type")
  status              String    @default("pending")
  requestedCategories String[]  @default([]) @map("requested_categories")
  result              Json      @default("{}") @map("result_json")
  lastError           String?   @map("last_error")
  startedAt           DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt         DateTime? @map("completed_at") @db.Timestamptz(6)
  failedAt            DateTime? @map("failed_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  merchant            Merchant  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  shop                Shop?     @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([merchantId, status, createdAt])
  @@index([shopId, status])
  @@map("merchant_memory_refresh_runs")
}
